@page "/belastingen"
@inject IAssetReader AssetReader
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject IGemeenteAanslagvoetService GemeenteService
@inject AangifteStateService AangifteStateService
@using BlazorTax.Belastingen.Berekening

<PageTitle>SOStax – Belastingen</PageTitle>

<h1>Personenbelasting AJ 2026</h1>
<p class="text-muted">Structuur met tabs per vak uit <code>structuur.md</code>.</p>

@if (!string.IsNullOrWhiteSpace(_errorMessage))
{
    <div class="alert alert-danger" role="alert">@_errorMessage</div>
}
else if (_vakSections.Count == 0)
{
    <p>Structuur laden...</p>
}
else
{
    <ul class="nav nav-tabs vak-tabs" role="tablist">
        @for (var i = 0; i < _vakSections.Count; i++)
        {
            var vak = _vakSections[i];
            var isActive = i == _activeTabIndex;
            var tabHref = Navigation.GetUriWithQueryParameter("vak", vak.Code);
            var tabIndex = i;

            <li class="nav-item" role="presentation">
                <a href="@tabHref"
                   class="nav-link @(isActive ? "active" : null)"
                   role="tab"
                   aria-selected="@isActive"
                   data-tab-index="@tabIndex"
                   @onclick:preventDefault
                   @onclick="() => SelectTab(tabIndex)">
                    @vak.Code
                </a>
            </li>
        }
    </ul>
 
    var activeSection = _vakSections[_activeTabIndex];

    <section class="vak-panel">
        <h2>@activeSection.Title</h2>

        @if (string.Equals(activeSection.Code, "VAK I", StringComparison.OrdinalIgnoreCase))
        {
            <VakIForm Data="AangifteStateService.State.VakI" />
        }
        else if (string.Equals(activeSection.Code, "VAK II", StringComparison.OrdinalIgnoreCase))
        {
            <VakIIForm Data="AangifteStateService.State.VakII" />
        }
        else if (string.Equals(activeSection.Code, "VAK III", StringComparison.OrdinalIgnoreCase))
        {
            <VakIIIForm Data="AangifteStateService.State.VakIII" />
        }
        else if (string.Equals(activeSection.Code, "VAK IV", StringComparison.OrdinalIgnoreCase))
        {
            <VakIVForm Data="AangifteStateService.State.VakIV" />
        }
        else if (string.Equals(activeSection.Code, "VAK V", StringComparison.OrdinalIgnoreCase))
        {
            <VakVForm Data="AangifteStateService.State.VakV" />
        }
        else if (string.Equals(activeSection.Code, "VAK VI", StringComparison.OrdinalIgnoreCase))
        {
            <VakVIForm Data="AangifteStateService.State.VakVI" />
        }
        else if (string.Equals(activeSection.Code, "VAK VII", StringComparison.OrdinalIgnoreCase))
        {
            <VakVIIForm Data="AangifteStateService.State.VakVII" />
        }
        else if (string.Equals(activeSection.Code, "VAK VIII", StringComparison.OrdinalIgnoreCase))
        {
            <VakVIIIForm Data="AangifteStateService.State.VakVIII" />
        }
        else if (string.Equals(activeSection.Code, "VAK IX", StringComparison.OrdinalIgnoreCase))
        {
            <VakIXForm Data="AangifteStateService.State.VakIX" />
        }
        else if (string.Equals(activeSection.Code, "VAK X", StringComparison.OrdinalIgnoreCase))
        {
            <VakXForm Data="AangifteStateService.State.VakX" />
        }
        else if (string.Equals(activeSection.Code, "VAK XI", StringComparison.OrdinalIgnoreCase))
        {
            <VakXIForm Data="AangifteStateService.State.VakXI" />
        }
        else if (string.Equals(activeSection.Code, "VAK XII", StringComparison.OrdinalIgnoreCase))
        {
            <VakXIIForm Data="AangifteStateService.State.VakXII" />
        }
        else if (string.Equals(activeSection.Code, "VAK XIII", StringComparison.OrdinalIgnoreCase))
        {
            <VakXIIIForm Data="AangifteStateService.State.VakXIII" />
        }
        else if (string.Equals(activeSection.Code, "VAK XIV", StringComparison.OrdinalIgnoreCase))
        {
            <VakXIVForm Data="AangifteStateService.State.VakXIV" />
        }
        else if (string.Equals(activeSection.Code, "VAK XV", StringComparison.OrdinalIgnoreCase))
        {
            <VakXVForm Data="AangifteStateService.State.VakXV" />
        }
        else if (string.Equals(activeSection.Code, "VAK XVI", StringComparison.OrdinalIgnoreCase))
        {
            <VakXVIForm Data="AangifteStateService.State.VakXVI" />
        }
        else if (string.Equals(activeSection.Code, "VAK XVII", StringComparison.OrdinalIgnoreCase))
        {
            <VakXVIIForm Data="AangifteStateService.State.VakXVII" />
        }
        else if (string.Equals(activeSection.Code, "VAK XVIII", StringComparison.OrdinalIgnoreCase))
        {
            <VakXVIIIForm Data="AangifteStateService.State.VakXVIII" />
        }
        else if (string.Equals(activeSection.Code, "VAK XIX", StringComparison.OrdinalIgnoreCase))
        {
            <VakXIXForm Data="AangifteStateService.State.VakXIX" />
        }
        else if (string.Equals(activeSection.Code, "VAK XX", StringComparison.OrdinalIgnoreCase))
        {
            <VakXXForm Data="AangifteStateService.State.VakXX" />
        }
        else if (string.Equals(activeSection.Code, "VAK XXI", StringComparison.OrdinalIgnoreCase))
        {
            <VakXXIForm Data="AangifteStateService.State.VakXXI" />
        }
        else if (string.Equals(activeSection.Code, "VAK XXII", StringComparison.OrdinalIgnoreCase))
        {
            <VakXXIIForm Data="AangifteStateService.State.VakXXII" />
        }
        else
        {
            <pre class="vak-markdown">@activeSection.Content</pre>
        }

        <div class="vak-nav-footer">
            @{
                var prevIndex = _activeTabIndex - 1;
                var nextIndex = _activeTabIndex + 1;
                var prevHref = prevIndex >= 0 ? Navigation.GetUriWithQueryParameter("vak", _vakSections[prevIndex].Code) : "#";
                var nextHref = nextIndex < _vakSections.Count ? Navigation.GetUriWithQueryParameter("vak", _vakSections[nextIndex].Code) : "#";
            }
            <a href="@prevHref"
               class="btn btn-outline-secondary @(_activeTabIndex == 0 ? "disabled" : null)"
               aria-disabled="@(_activeTabIndex == 0)"
               @onclick:preventDefault
               @onclick="async () => { if (_activeTabIndex > 0) await SelectTab(prevIndex); }">
                &#8592; @(prevIndex >= 0 ? _vakSections[prevIndex].Code : "")
            </a>
            <span class="vak-nav-counter">@(_activeTabIndex + 1) / @_vakSections.Count</span>
            <a href="@nextHref"
               class="btn btn-outline-primary @(_activeTabIndex == _vakSections.Count - 1 ? "disabled" : null)"
               aria-disabled="@(_activeTabIndex == _vakSections.Count - 1)"
               @onclick:preventDefault
               @onclick="async () => { if (_activeTabIndex < _vakSections.Count - 1) await SelectTab(nextIndex); }">
                @(nextIndex < _vakSections.Count ? _vakSections[nextIndex].Code : "") &#8594;
            </a>
        </div>
    </section>

    <!-- Berekeningsinstellingen -->
    <section class="berekening-settings mt-4 p-3 border rounded">
        <h3>⚙️ Berekeningsinstellingen</h3>
        <div class="row g-3">
            <div class="col-md-4">
                <label class="form-label">Gewest</label>
                <select class="form-select" @bind="AangifteStateService.State.Gewest">
                    <option value="@Gewest.Vlaanderen">Vlaanderen</option>
                    <option value="@Gewest.Wallonie">Wallonië</option>
                    <option value="@Gewest.Brussel">Brussel</option>
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label">Gemeente</label>
                <input type="text" class="form-control" 
                       value="@_geselecteerdeGemeente" 
                       @oninput="OnGemeenteInput"
                       @onfocus="() => { _toonGemeenteSuggesties = true; UpdateGemeenteSuggesties(); }"
                       @onblur="OnGemeenteBlur"
                       placeholder="Typ een gemeente..."
                       autocomplete="off" />
                @if (_toonGemeenteSuggesties && _gemeenteSuggesties.Count > 0)
                {
                    <div class="dropdown-menu show" style="max-height: 200px; overflow-y: auto; width: 100%; position: absolute; z-index: 1000;">
                        @foreach (var gemeente in _gemeenteSuggesties)
                        {
                            <button type="button" class="dropdown-item" @onmousedown="() => SelecteerGemeente(gemeente)">
                                @gemeente
                            </button>
                        }
                    </div>
                }
            </div>
            <div class="col-md-4">
                <label class="form-label">Gemeentebelasting (%)</label>
                <input type="number" class="form-control" step="0.01" min="0" max="15"
                       @bind="AangifteStateService.State.GemeentebelastingPercentage" 
                       readonly="@(!string.IsNullOrEmpty(_geselecteerdeGemeente))"
                       title="@(_geselecteerdeGemeente != null ? $"Automatisch geladen voor {_geselecteerdeGemeente}" : "Voer handmatig in of selecteer gemeente")" />
            </div>
        </div>
        <div class="mt-3">
            <button type="button" class="btn btn-primary btn-lg" @onclick="Bereken">
                🧮 Bereken belasting
            </button>
        </div>
    </section>

    <!-- Resultaat -->
    @if (AangifteStateService.LaatsteResultaat is not null)
    {
        <section class="berekening-resultaat mt-4 p-3 border rounded">
            <div class="d-flex justify-content-between align-items-center mb-2 no-print">
                <h3 class="mb-0">📊 Berekeningsresultaat</h3>
                <button class="btn btn-outline-secondary btn-sm" @onclick="PrintResultaat">
                    🖨️ Afdrukken / Opslaan als PDF
                </button>
            </div>
            <h3 class="d-none print-only">Belastingberekening AJ2026</h3>
            <table class="table table-sm table-hover">
                <thead>
                    <tr>
                        <th>Omschrijving</th>
                        <th class="text-end">Bedrag</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var regel in AangifteStateService.LaatsteResultaat.DetailRegels)
                    {
                        <tr class="@(regel.IsSubtotaal ? "table-active fw-bold" : "")">
                            <td>@regel.Omschrijving</td>
                            <td class="text-end @(regel.Bedrag < 0 ? "text-success" : "")">
                                @regel.Bedrag.ToString("N2") €
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            <div class="alert @(AangifteStateService.LaatsteResultaat.Eindresultaat >= 0 ? "alert-warning" : "alert-success") fs-4 text-center">
                @if (AangifteStateService.LaatsteResultaat.Eindresultaat >= 0)
                {
                    <strong>Te betalen: @AangifteStateService.LaatsteResultaat.Eindresultaat.ToString("N2") €</strong>
                }
                else
                {
                    <strong>Terug te krijgen: @((-AangifteStateService.LaatsteResultaat.Eindresultaat).ToString("N2")) €</strong>
                }
            </div>
        </section>
    }
}

@code {
    private readonly List<VakSection> _vakSections = [];
    private string? _errorMessage;
    private int _activeTabIndex;

    private async Task PrintResultaat()
    {
        await JS.InvokeVoidAsync("window.print");
    }

    private string? _geselecteerdeGemeente;
    private List<string> _gemeenteSuggesties = new();
    private bool _toonGemeenteSuggesties = false;

    private string? GeselecteerdeGemeente
    {
        get => _geselecteerdeGemeente;
        set
        {
            if (_geselecteerdeGemeente != value)
            {
                _geselecteerdeGemeente = value;
                UpdateGemeenteSuggesties();
            }
        }
    }

    [SupplyParameterFromQuery(Name = "vak")]
    public string? VakCode { get; set; }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Initialize gemeente service
            if (!GemeenteService.IsInitialized)
            {
                await GemeenteService.InitializeAsync(AssetReader);
            }

            var markdown = await AssetReader.GetStringAsync("belastingen/structuur.md");

            if (markdown.Contains("<!DOCTYPE html>", StringComparison.OrdinalIgnoreCase))
            {
                _errorMessage = "De markdown is niet als statisch bestand gevonden (fallback naar index.html).";
                return;
            }

            _vakSections.AddRange(VakStructuurParser.ParseSections(markdown)
                .Where(v => !string.Equals(v.Code, "VAK V C", StringComparison.OrdinalIgnoreCase)));

            TrySetActiveTabFromQuery();

            if (_vakSections.Count == 0)
            {
                _errorMessage = "Geen VAK-secties gevonden in structuur.md.";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Structuur kon niet geladen worden: {ex.Message}";
        }
    }

    protected override void OnParametersSet()
    {
        TrySetActiveTabFromQuery();
    }

    private void TrySetActiveTabFromQuery()
    {
        if (_vakSections.Count == 0 || string.IsNullOrWhiteSpace(VakCode))
        {
            return;
        }

        var index = _vakSections.FindIndex(vak => string.Equals(vak.Code, VakCode, StringComparison.OrdinalIgnoreCase));
        if (index >= 0)
        {
            _activeTabIndex = index;
        }
    }

    private async Task SelectTab(int tabIndex)
    {
        if (tabIndex < 0 || tabIndex >= _vakSections.Count) return;

        _activeTabIndex = tabIndex;

        var targetVakCode = _vakSections[tabIndex].Code;
        var uriWithQuery = Navigation.GetUriWithQueryParameter("vak", targetVakCode);
        Navigation.NavigateTo(uriWithQuery, replace: true);

        await JS.InvokeVoidAsync("scrollTabIntoView", $"[data-tab-index='{tabIndex}']");
    }

    private void UpdateGemeenteSuggesties()
    {
        if (!GemeenteService.IsInitialized)
            return;

        if (string.IsNullOrWhiteSpace(_geselecteerdeGemeente))
        {
            _gemeenteSuggesties = GemeenteService.GetGemeenteNamen().Take(10).ToList();
        }
        else
        {
            _gemeenteSuggesties = GemeenteService.GetGemeenteNamen()
                .Where(g => g.Contains(_geselecteerdeGemeente, StringComparison.OrdinalIgnoreCase))
                .Take(10)
                .ToList();
        }
    }

    private void OnGemeenteInput(ChangeEventArgs e)
    {
        _geselecteerdeGemeente = e.Value?.ToString();
        _toonGemeenteSuggesties = true;
        UpdateGemeenteSuggesties();
    }

    private async Task OnGemeenteBlur()
    {
        // Delay sluiten zodat de onclick event van de dropdown kan afvuren
        await Task.Delay(200);
        _toonGemeenteSuggesties = false;
    }

    private void SelecteerGemeente(string gemeente)
    {
        _geselecteerdeGemeente = gemeente;
        _toonGemeenteSuggesties = false;

        // Automatisch de aanslagvoet laden voor 2026
        var aanslagvoet = GemeenteService.GetAanslagvoet(gemeente, 2026);
        if (aanslagvoet.HasValue)
        {
            AangifteStateService.State.GemeentebelastingPercentage = aanslagvoet.Value;
        }
    }

    private void Bereken()
    {
        AangifteStateService.Bereken();
    }
}
