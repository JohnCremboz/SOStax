<EditForm Model="Data" class="vak4-form">

    <div class="vak2-title">Vak XXI &ndash; WINST EN BATEN VAN EEN VORIGE BEROEPSWERKZAAMHEID</div>

    <div class="vak4-header-row"><div></div><div class="vak4-col-head">Belastingplichtige</div><div class="vak4-col-head">Partner</div></div>

    <!-- 1. Stopzettingsmeerwaarden -->
    <div class="vak4-group">
        <div class="vak4-q-label">1. Stopzettingsmeerwaarden:</div>
        <div class="vak4-subrow">
            <div class="vak4-q-text vak4-indent">a) belastbaar tegen 10%:</div>
            <div class="vak4-col-duo">
                <div class="vak4-input-cell"><span class="vak2-code">1686-00</span><InputNumber @bind-Value="Data.Code1686" class="vak4-amount" /></div>
                <div class="vak4-input-cell"><span class="vak2-code">2686-00</span><InputNumber @bind-Value="Data.Code2686" class="vak4-amount" /></div>
            </div>
        </div>
        <div class="vak4-subrow">
            <div class="vak4-q-text vak4-indent">b) belastbaar tegen 16,5%:</div>
            <div class="vak4-col-duo">
                <div class="vak4-input-cell"><span class="vak2-code">1690-00</span><InputNumber @bind-Value="Data.Code1690" class="vak4-amount" /></div>
                <div class="vak4-input-cell"><span class="vak2-code">2690-00</span><InputNumber @bind-Value="Data.Code2690" class="vak4-amount" /></div>
            </div>
        </div>
        <div class="vak4-subrow">
            <div class="vak4-q-text vak4-indent">c) belastbaar tegen 33%:</div>
            <div class="vak4-col-duo">
                <div class="vak4-input-cell"><span class="vak2-code">1691-00</span><InputNumber @bind-Value="Data.Code1691" class="vak4-amount" /></div>
                <div class="vak4-input-cell"><span class="vak2-code">2691-00</span><InputNumber @bind-Value="Data.Code2691" class="vak4-amount" /></div>
            </div>
        </div>
        <div class="vak4-subrow">
            <div class="vak4-q-text vak4-indent">d) gezamenlijk belastbaar:</div>
            <div class="vak4-col-duo">
                <div class="vak4-input-cell"><span class="vak2-code">1692-00</span><InputNumber @bind-Value="Data.Code1692" class="vak4-amount" /></div>
                <div class="vak4-input-cell"><span class="vak2-code">2692-00</span><InputNumber @bind-Value="Data.Code2692" class="vak4-amount" /></div>
            </div>
        </div>
    </div>

    <div class="vak4-row">
        <div class="vak4-q-text">2. Kosten overdracht vorig belastbaar tijdperk:</div>
        <div class="vak4-col-duo">
            <div class="vak4-input-cell"><span class="vak2-code">1693-00</span><InputNumber @bind-Value="Data.Code1693" class="vak4-amount" /></div>
            <div class="vak4-input-cell"><span class="vak2-code">2693-00</span><InputNumber @bind-Value="Data.Code2693" class="vak4-amount" /></div>
        </div>
    </div>

    <!-- 3. Premies/vergoedingen -->
    <div class="vak4-group">
        <div class="vak4-q-label">3. Premies en vergoedingen:</div>
        <div class="vak4-subrow">
            <div class="vak4-q-text vak4-indent">a) belastbaar tegen 12,5%:</div>
            <div class="vak4-col-duo">
                <div class="vak4-input-cell"><span class="vak2-code">1687-00</span><InputNumber @bind-Value="Data.Code1687" class="vak4-amount" /></div>
                <div class="vak4-input-cell"><span class="vak2-code">2687-00</span><InputNumber @bind-Value="Data.Code2687" class="vak4-amount" /></div>
            </div>
        </div>
        <div class="vak4-subrow">
            <div class="vak4-q-text vak4-indent">b) belastbaar tegen 16,5%:</div>
            <div class="vak4-col-duo">
                <div class="vak4-input-cell"><span class="vak2-code">1694-00</span><InputNumber @bind-Value="Data.Code1694" class="vak4-amount" /></div>
                <div class="vak4-input-cell"><span class="vak2-code">2694-00</span><InputNumber @bind-Value="Data.Code2694" class="vak4-amount" /></div>
            </div>
        </div>
    </div>

    <div class="vak4-row">
        <div class="vak4-q-text">4. Winst of baten na stopzetting:</div>
        <div class="vak4-col-duo">
            <div class="vak4-input-cell"><span class="vak2-code">1695-00</span><InputNumber @bind-Value="Data.Code1695" class="vak4-amount" /></div>
            <div class="vak4-input-cell"><span class="vak2-code">2695-00</span><InputNumber @bind-Value="Data.Code2695" class="vak4-amount" /></div>
        </div>
    </div>

    <div class="vak4-row">
        <div class="vak4-q-text">5. Baten uit sportieve activiteiten:</div>
        <div class="vak4-col-duo">
            <div class="vak4-input-cell"><span class="vak2-code">1688-00</span><InputNumber @bind-Value="Data.Code1688" class="vak4-amount" /></div>
            <div class="vak4-input-cell"><span class="vak2-code">2688-00</span><InputNumber @bind-Value="Data.Code2688" class="vak4-amount" /></div>
        </div>
    </div>

    <div class="vak4-row">
        <div class="vak4-q-text">6. Baten van opleiders/trainers in de sport:</div>
        <div class="vak4-col-duo">
            <div class="vak4-input-cell"><span class="vak2-code">1689-00</span><InputNumber @bind-Value="Data.Code1689" class="vak4-amount" /></div>
            <div class="vak4-input-cell"><span class="vak2-code">2689-00</span><InputNumber @bind-Value="Data.Code2689" class="vak4-amount" /></div>
        </div>
    </div>

    <!-- 7. Beroepskosten -->
    <div class="vak4-group">
        <div class="vak4-q-label">7. Beroepskosten:</div>
        <div class="vak4-subrow">
            <div class="vak4-q-text vak4-indent">a) overdracht vorig belastbaar tijdperk:</div>
            <div class="vak4-col-duo">
                <div class="vak4-input-cell"><span class="vak2-code">1696-00</span><InputNumber @bind-Value="Data.Code1696" class="vak4-amount" /></div>
                <div class="vak4-input-cell"><span class="vak2-code">2696-00</span><InputNumber @bind-Value="Data.Code2696" class="vak4-amount" /></div>
            </div>
        </div>
        <div class="vak4-subrow">
            <div class="vak4-q-text vak4-indent">b) andere beroepskosten:</div>
            <div class="vak4-col-duo">
                <div class="vak4-input-cell"><span class="vak2-code">1697-00</span><InputNumber @bind-Value="Data.Code1697" class="vak4-amount" /></div>
                <div class="vak4-input-cell"><span class="vak2-code">2697-00</span><InputNumber @bind-Value="Data.Code2697" class="vak4-amount" /></div>
            </div>
        </div>
    </div>

    <div class="vak4-row">
        <div class="vak4-q-text">8. Hervatting na ontslag of pensionering:</div>
        <div class="vak4-col-duo">
            <div class="vak4-input-cell"><span class="vak2-code">1698-48</span><InputNumber @bind-Value="Data.Code1698" class="vak4-amount" /></div>
            <div class="vak4-input-cell"><span class="vak2-code">2698-18</span><InputNumber @bind-Value="Data.Code2698" class="vak4-amount" /></div>
        </div>
    </div>

    <!-- 9. Buitenlandse oorsprong -->
    <div class="vak2-section-header">Inkomsten van buitenlandse oorsprong</div>
    <div class="vak3-buitenland-section">
        @foreach (var rij in Data.BuitenlandseInkomsten)
        {
            <div class="vak3-buitenland-row">
                <div class="vak3-buitenland-cell"><label>Land:</label><InputText @bind-Value="rij.Land" class="vak3-text-input" /></div>
                <div class="vak3-buitenland-cell"><label>Code:</label><InputText @bind-Value="rij.Code" class="vak3-text-input vak3-code-input" /></div>
                <div class="vak3-buitenland-cell"><label>Bedrag:</label><InputNumber @bind-Value="rij.Bedrag" class="vak3-amount-input" /></div>
                <div class="vak3-buitenland-cell">
                    <label>Type:</label>
                    <InputSelect @bind-Value="rij.TypeVermindering" class="vak5-select">
                        <option value="">— kies —</option>
                        <option value="vrijstelling">Vrijstelling met progressievoorbehoud</option>
                        <option value="vermindering">Vermindering tot de helft</option>
                    </InputSelect>
                </div>
            </div>
        }
        <button type="button" class="vak3-add-btn" @onclick="() => Data.BuitenlandseInkomsten.Add(new())">+ rij</button>
    </div>

    <!-- 10. Feitelijke vereniging verlies info -->
    <div class="vak4-header-row"><div></div><div class="vak4-col-head">Belastingplichtige</div><div class="vak4-col-head">Partner</div></div>

    <div class="vak4-group">
        <div class="vak4-q-label">10. Verliezen van een feitelijke vereniging (info):</div>
        <div class="vak4-subrow">
            <div class="vak4-q-text vak4-indent">Naam feitelijke vereniging:</div>
            <div class="vak4-col-duo">
                <div class="vak4-input-cell"><InputText @bind-Value="Data.VerliesVerenigingNaam1" class="vak3-text-input" /></div>
                <div class="vak4-input-cell"><InputText @bind-Value="Data.VerliesVerenigingNaam2" class="vak3-text-input" /></div>
            </div>
        </div>
        <div class="vak4-subrow">
            <div class="vak4-q-text vak4-indent">Adres feitelijke vereniging:</div>
            <div class="vak4-col-duo">
                <div class="vak4-input-cell"><InputText @bind-Value="Data.VerliesVerenigingAdres1" class="vak3-text-input" /></div>
                <div class="vak4-input-cell"><InputText @bind-Value="Data.VerliesVerenigingAdres2" class="vak3-text-input" /></div>
            </div>
        </div>
    </div>

</EditForm>

@code {
    [Parameter] public VakXXIData Data { get; set; } = new();
}
