@inject IAssetReader AssetReader
@inject IJSRuntime JS
@using System.Reflection
@using System.Globalization
@using Microsoft.AspNetCore.Components.Forms
@using System.Text

<div class="snelle-invoer-container">
    <div class="vak2-title">SNELLE INVOERING</div>
    <hr />

    <div class="snelle-invoer-row">
        <label class="snelle-invoer-label">Code :</label>
        <input type="text"
               class="form-control snelle-invoer-code"
               placeholder="bijv. 1250"
               @bind="_code"
               @bind:event="oninput"
               @onkeydown="HandleKeyDown"
               @ref="_codeInput" />
        <label class="snelle-invoer-label">Waarde :</label>
        <input type="text"
               class="form-control snelle-invoer-waarde"
               @bind="_waarde"
               @bind:event="oninput"
               @onkeydown="HandleKeyDown" />
        <button type="button" class="btn btn-primary" @onclick="ToevoegenAsync">TOEVOEGEN</button>
    </div>

    @if (!string.IsNullOrEmpty(_foutmelding))
    {
        <div class="alert alert-danger mt-2">@_foutmelding</div>
    }

    <div class="mt-3">
        <button type="button" class="btn btn-primary" @onclick="Valideren">VALIDEREN VAN DE GEGEVENS</button>
    </div>

    <div class="mt-3 d-flex align-items-center gap-2">
        <label class="snelle-invoer-label mb-0">CSV importeren:</label>
        <InputFile OnChange="ImporteerCsvAsync" accept=".csv,.txt" class="form-control" style="max-width:300px;" />
        <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="DownloadTemplateAsync"
                title="Download een vooringevuld sjabloon met alle beschikbare rubrieken">
            Template downloaden
        </button>
    </div>
    <div class="text-muted small mt-1">
        Formaat: <code>rubriek;bedrag</code> — één rubriek per lijn. Regels die beginnen met <code>#</code> worden genegeerd.
        Download het sjabloon, vul de bedragen in die op u van toepassing zijn, en importeer het bestand.
    </div>

    @if (_importFouten.Count > 0)
    {
        <div class="alert alert-danger mt-2">
            <strong>Import mislukt — corrigeer de volgende fouten:</strong>
            <ul class="mb-0 mt-1">
                @foreach (var fout in _importFouten)
                {
                    <li>@fout</li>
                }
            </ul>
        </div>
    }
    @if (_importSucces)
    {
        <div class="alert alert-success mt-2">Import geslaagd.</div>
    }

    @if (_entries.Count > 0)
    {
        <table class="table table-sm table-hover mt-3">
            <thead>
                <tr>
                    <th>Code</th>
                    <th>Omschrijving</th>
                    <th>Waarde</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var entry in _entries.ToList())
                {
                    <tr>
                        <td><code>@entry.Code</code></td>
                        <td>@entry.Omschrijving</td>
                        <td>@entry.Waarde</td>
                        <td>
                            <button type="button" class="btn btn-sm btn-outline-danger"
                                    @onclick="() => Verwijderen(entry)">✕</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@code {
    [Parameter] public AangifteState State { get; set; } = default!;

    private ElementReference _codeInput;
    private string _code = string.Empty;
    private string _waarde = string.Empty;
    private string _foutmelding = string.Empty;
    private Dictionary<string, string> _codeOmschrijvingen = new(StringComparer.OrdinalIgnoreCase);
    private readonly List<SnelleInvoerEntry> _entries = [];
    private readonly List<string> _importFouten = [];
    private bool _importSucces;

    private static readonly string[] CsvBestanden =
    [
        "belastingen/VAKII.csv",
        "belastingen/VAKIIB.csv",
        "belastingen/VAKIII.csv",
        "belastingen/VAKIVA.csv",
        "belastingen/VAKIVB.csv",
        "belastingen/VAKIVC.csv",
        "belastingen/VAKIVD.csv",
        "belastingen/VAKIVE.csv",
        "belastingen/VAKIVF.csv",
        "belastingen/VAKIVG.csv",
        "belastingen/VAKIVH.csv",
        "belastingen/VAKIVI.csv",
        "belastingen/VAKIVJ.csv",
        "belastingen/VAKIVK.csv",
        "belastingen/VAKIVL.csv",
        "belastingen/VAKIVM.csv",
        "belastingen/VAKIVN.csv",
        "belastingen/VAKV.csv",
        "belastingen/VAKVI.csv",
        "belastingen/VakVII.csv",
        "belastingen/VAKVIII.csv",
        "belastingen/VakIX.csv",
        "belastingen/VakIX-II.csv",
        "belastingen/VakIX4.csv",
        "belastingen/VakIX5.csv",
        "belastingen/VakIX6.csv",
        "belastingen/VAKIXb.csv",
        "belastingen/VAKIXc.csv",
        "belastingen/VakX.csv",
        "belastingen/VakXI.csv",
        "belastingen/VakXII.csv",
        "belastingen/VakXIII.csv",
    ];

    protected override async Task OnInitializedAsync()
    {
        foreach (var bestand in CsvBestanden)
        {
            try
            {
                var inhoud = await AssetReader.GetStringAsync(bestand);
                if (!inhoud.Contains("<!DOCTYPE html>", StringComparison.OrdinalIgnoreCase))
                {
                    ParseCsvInto(inhoud, _codeOmschrijvingen);
                }
            }
            catch
            {
                // Bestand niet gevonden – overslaan
            }
        }
    }

    private static void ParseCsvInto(string csv, Dictionary<string, string> doel)
    {
        using var reader = new StringReader(csv.Replace("\r\n", "\n", StringComparison.Ordinal));
        bool headerOvergeslagen = false;
        string? lijn;

        while ((lijn = reader.ReadLine()) is not null)
        {
            if (string.IsNullOrWhiteSpace(lijn)) continue;
            if (!headerOvergeslagen) { headerOvergeslagen = true; continue; }

            var komma = lijn.IndexOf(',');
            if (komma <= 0) continue;

            var code = lijn[..komma].Trim();
            var omschrijving = lijn[(komma + 1)..].Trim();
            doel.TryAdd(code, omschrijving);
        }
    }

    private async Task ToevoegenAsync()
    {
        _foutmelding = string.Empty;
        var code = _code.Trim();
        var waarde = _waarde.Trim();

        if (string.IsNullOrWhiteSpace(code))
        {
            _foutmelding = "Vul een code in.";
            await _codeInput.FocusAsync();
            return;
        }

        if (!TrySetWaarde(code, waarde))
        {
            _foutmelding = $"Code '{code}' niet gevonden of ongeldige waarde '{waarde}'.";
            await _codeInput.FocusAsync();
            return;
        }

        _entries.Add(new SnelleInvoerEntry(code, ZoekOmschrijving(code), waarde));
        _code = string.Empty;
        _waarde = string.Empty;
        await _codeInput.FocusAsync();
    }

    private void Valideren()
    {
        // Vul ontbrekende omschrijvingen in
        for (int i = 0; i < _entries.Count; i++)
        {
            if (string.IsNullOrEmpty(_entries[i].Omschrijving))
            {
                var numericPart = _entries[i].Code.Contains('-')
                    ? _entries[i].Code.Split('-')[0]
                    : _entries[i].Code;

                var match = _codeOmschrijvingen.FirstOrDefault(kv =>
                    kv.Key.StartsWith(numericPart + "-", StringComparison.OrdinalIgnoreCase)
                    || string.Equals(kv.Key, _entries[i].Code, StringComparison.OrdinalIgnoreCase));

                var omschrijving = !string.IsNullOrEmpty(match.Key) ? match.Value : "(onbekend)";
                _entries[i] = _entries[i] with { Omschrijving = omschrijving };
            }
        }
    }

    private void Verwijderen(SnelleInvoerEntry entry)
    {
        TryClearWaarde(entry.Code);
        _entries.Remove(entry);
    }

    private void TryClearWaarde(string code)
    {
        var numericCode = code.Contains('-') ? code.Split('-')[0] : code;

        if (numericCode is "1001" or "1002" or "1010")
        {
            State.VakII.BurgerlijkeStaat = string.Empty;
            return;
        }

        if ((numericCode == "1250" || numericCode == "2250") && State.VakIV is not null)
        {
            RemoveFromFicheList(numericCode == "1250", State.VakIV.Fiches1250, State.VakIV.Fiches2250);
            return;
        }
        if ((numericCode == "1286" || numericCode == "2286") && State.VakIV is not null)
        {
            RemoveFromFicheList(numericCode == "1286", State.VakIV.Fiches1286, State.VakIV.Fiches2286);
            return;
        }
        if ((numericCode == "1225" || numericCode == "2225") && State.VakV is not null)
        {
            RemoveFromFicheList(numericCode == "1225", State.VakV.Fiches1225, State.VakV.Fiches2225);
            return;
        }

        var propNaam = "Code" + numericCode;
        foreach (var staatsProp in typeof(AangifteState).GetProperties())
        {
            var vakData = staatsProp.GetValue(State);
            if (vakData is null) continue;

            var veldProp = vakData.GetType().GetProperty(propNaam);
            if (veldProp is null || !veldProp.CanWrite) continue;

            // Nullable types → null; bool → false; overige value types → default
            var doelType = veldProp.PropertyType;
            if (Nullable.GetUnderlyingType(doelType) is not null)
                veldProp.SetValue(vakData, null);
            else if (doelType == typeof(bool))
                veldProp.SetValue(vakData, false);
            else
                veldProp.SetValue(vakData, Activator.CreateInstance(doelType));
            return;
        }
    }

    private static void RemoveFromFicheList(bool isPrimary, List<decimal?> primaryList, List<decimal?> partnerList)
    {
        var list = isPrimary ? primaryList : partnerList;
        var otherList = isPrimary ? partnerList : primaryList;

        // Verwijder de laatste ingevulde waarde
        for (int i = list.Count - 1; i >= 0; i--)
        {
            if (list[i].HasValue)
            {
                list[i] = null;
                // Als beide lijsten op deze positie null zijn en het niet de eerste rij is, rij verwijderen
                if (i > 0 && !otherList[i].HasValue)
                {
                    list.RemoveAt(i);
                    otherList.RemoveAt(i);
                }
                return;
            }
        }
    }

    private async Task ImporteerCsvAsync(InputFileChangeEventArgs e)
    {
        _importFouten.Clear();
        _importSucces = false;

        using var stream = e.File.OpenReadStream(maxAllowedSize: 1024 * 1024);
        using var reader = new StreamReader(stream);
        var inhoud = await reader.ReadToEndAsync();

        // ── Fase 1: parse en valideer alle regels ──────────────────────────
        var geldigeRegels = new List<(string Code, string Waarde)>();
        int lijnnummer = 0;

        foreach (var lijn in inhoud.Replace("\r\n", "\n", StringComparison.Ordinal).Split('\n'))
        {
            lijnnummer++;
            if (string.IsNullOrWhiteSpace(lijn)) continue;
            if (lijn.TrimStart().StartsWith('#')) continue; // commentaarregel

            var delen = lijn.Split(';', 3); // max 3 delen; derde kolom (omschrijving) wordt genegeerd
            if (delen.Length < 2)
            {
                _importFouten.Add($"Lijn {lijnnummer}: verwacht formaat 'rubriek;bedrag', gevonden '{lijn}'.");
                continue;
            }

            var code = delen[0].Trim();
            var waarde = delen[1].Trim();

            if (string.IsNullOrWhiteSpace(code))
            {
                _importFouten.Add($"Lijn {lijnnummer}: lege code.");
                continue;
            }

            var fout = ValideerCodeEnWaarde(code, waarde);
            if (fout is not null)
                _importFouten.Add($"Lijn {lijnnummer} ({code}): {fout}");
            else
                geldigeRegels.Add((code, waarde));
        }

        if (_importFouten.Count > 0) return;

        // ── Fase 2: alles geldig → toepassen ───────────────────────────────
        foreach (var (code, waarde) in geldigeRegels)
        {
            TrySetWaarde(code, waarde);
            _entries.Add(new SnelleInvoerEntry(code, ZoekOmschrijving(code), waarde));
        }

        _importSucces = true;
    }

    private async Task DownloadTemplateAsync()
    {
        var sb = new StringBuilder();
        sb.AppendLine("# SOStax – aangifte template");
        sb.AppendLine("# Formaat: rubriek;bedrag;omschrijving (derde kolom wordt genegeerd bij import)");
        sb.AppendLine("# Vul de bedragen in die op u van toepassing zijn.");
        sb.AppendLine("# Verwijder of laat leeg wat niet van toepassing is.");
        sb.AppendLine("# Regels die beginnen met # worden genegeerd.");
        sb.AppendLine("#");

        var gesorteerd = _codeOmschrijvingen
            .OrderBy(kv =>
            {
                var numStr = kv.Key.Contains('-') ? kv.Key.Split('-')[0] : kv.Key;
                return int.TryParse(numStr, out int n) ? n : int.MaxValue;
            })
            .ThenBy(kv => kv.Key);

        foreach (var (code, omschrijving) in gesorteerd)
            sb.AppendLine($"{code};;{omschrijving}");

        await JS.InvokeVoidAsync("downloadTextFile", "aangifte-template.csv", sb.ToString());
    }

    private string? ValideerCodeEnWaarde(string code, string waarde)
    {
        var doelType = ZoekDoelType(code);
        if (doelType is null)
            return "code niet gevonden in de aangifte.";

        if (doelType == typeof(bool))
            return null; // bool aanvaardt altijd een waarde

        var geconverteerd = GetConvertedValue(doelType, waarde);
        if (geconverteerd is null)
            return $"waarde '{waarde}' is geen geldig getal.";

        return null;
    }

    private Type? ZoekDoelType(string code)
    {
        var numericCode = code.Contains('-') ? code.Split('-')[0] : code;

        if (numericCode is "1250" or "2250" or "1286" or "2286" or "1225" or "2225")
            return typeof(decimal);

        if (numericCode is "1001" or "1002" or "1010")
            return typeof(bool);

        var propNaam = "Code" + numericCode;
        foreach (var staatsProp in typeof(AangifteState).GetProperties())
        {
            var vakData = staatsProp.GetValue(State);
            if (vakData is null) continue;
            var veldProp = vakData.GetType().GetProperty(propNaam);
            if (veldProp is null || !veldProp.CanWrite) continue;
            return Nullable.GetUnderlyingType(veldProp.PropertyType) ?? veldProp.PropertyType;
        }
        return null;
    }

    private string ZoekOmschrijving(string code)
    {
        if (_codeOmschrijvingen.TryGetValue(code, out var desc))
            return desc;

        var numericPart = code.Contains('-') ? code.Split('-')[0] : code;
        var match = _codeOmschrijvingen.FirstOrDefault(kv =>
            kv.Key.StartsWith(numericPart + "-", StringComparison.OrdinalIgnoreCase));
        return match.Value ?? string.Empty;
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await ToevoegenAsync();
        }
    }

    private bool TrySetWaarde(string code, string waarde)
    {
        // Ondersteuning voor formaat "1250-11" of "1250" → zoekt property "Code1250"
        var numericCode = code.Contains('-') ? code.Split('-')[0] : code;
        var propNaam = "Code" + numericCode;

        // Burgerlijke staat: codes 1001/1002/1010 met waarde "1" zetten BurgerlijkeStaat
        if (numericCode is "1001" or "1002" or "1010")
        {
            var isTruthy = waarde.Trim().ToLowerInvariant() is "1" or "true" or "ja" or "x";
            if (isTruthy)
                State.VakII.BurgerlijkeStaat = numericCode;
            return isTruthy;
        }

        // Speciale behandeling voor fiche codes
        // Code 250 = fiches 281.10 (wedden/lonen)
        // Code 286 = bedrijfsvoorheffing Vak IV
        // Code 225 = bedrijfsvoorheffing Vak V
        if ((numericCode == "1250" || numericCode == "2250") && State.VakIV is not null)
        {
            return AddToFicheList(waarde, numericCode == "1250",
                State.VakIV.Fiches1250, State.VakIV.Fiches2250);
        }

        if ((numericCode == "1286" || numericCode == "2286") && State.VakIV is not null)
        {
            return AddToFicheList(waarde, numericCode == "1286",
                State.VakIV.Fiches1286, State.VakIV.Fiches2286);
        }

        if ((numericCode == "1225" || numericCode == "2225") && State.VakV is not null)
        {
            return AddToFicheList(waarde, numericCode == "1225",
                State.VakV.Fiches1225, State.VakV.Fiches2225);
        }


        foreach (var staatsProp in typeof(AangifteState).GetProperties())
        {
            var vakData = staatsProp.GetValue(State);
            if (vakData is null) continue;

            var veldProp = vakData.GetType().GetProperty(propNaam);
            if (veldProp is null || !veldProp.CanWrite) continue;

            var doelType = Nullable.GetUnderlyingType(veldProp.PropertyType) ?? veldProp.PropertyType;

            try
            {
                object? geconverteerdeWaarde = GetConvertedValue(doelType, waarde);

                if (geconverteerdeWaarde is not null || doelType == typeof(string))
                {
                    veldProp.SetValue(vakData, geconverteerdeWaarde);
                    return true;
                }
            }
            catch
            {
                // Conversie mislukt – volgende vak proberen
            }
        }

        return false;
    }

    private static object? GetConvertedValue(Type doelType, string waarde)
    {
        if (doelType == typeof(bool))
        {
            // "1", "true", "ja" = true; alles anders of leeg = false
            return waarde.Trim().ToLowerInvariant() is "1" or "true" or "ja" or "x";
        }
        if (doelType == typeof(int))
        {
            return int.TryParse(waarde, NumberStyles.Integer, CultureInfo.InvariantCulture, out int intVal)
                ? intVal : null;
        }
        if (doelType == typeof(decimal))
        {
            var normalized = waarde.Replace(',', '.');
            return decimal.TryParse(normalized, NumberStyles.Number, CultureInfo.InvariantCulture, out decimal decVal)
                ? decVal : null;
        }
        if (doelType == typeof(string))
        {
            return waarde;
        }
        return null;
    }

    private bool AddToFicheList(string waarde, bool isPrimary, List<decimal?> primaryList, List<decimal?> partnerList)
    {
        var normalized = waarde.Replace(',', '.');
        if (!decimal.TryParse(normalized, NumberStyles.Number, CultureInfo.InvariantCulture, out var bedrag))
            return false;

        if (isPrimary)
        {
            // Voeg toe aan belastingplichtige fiches
            var lastIndex = primaryList.Count - 1;
            if (primaryList[lastIndex].HasValue)
            {
                // Laatste fiche is al ingevuld, voeg nieuwe toe
                primaryList.Add(bedrag);
                partnerList.Add(null); // Sync partner lijst
            }
            else
            {
                // Vul de laatste lege fiche in
                primaryList[lastIndex] = bedrag;
            }
        }
        else
        {
            // Voeg toe aan partner fiches
            var lastIndex = partnerList.Count - 1;
            if (partnerList[lastIndex].HasValue)
            {
                // Laatste fiche is al ingevuld, voeg nieuwe toe
                partnerList.Add(bedrag);
                primaryList.Add(null); // Sync belastingplichtige lijst
            }
            else
            {
                // Vul de laatste lege fiche in
                partnerList[lastIndex] = bedrag;
            }
        }
        return true;
    }

    private sealed record SnelleInvoerEntry(string Code, string Omschrijving, string Waarde)
    {
        public string Omschrijving { get; set; } = Omschrijving;
    }
}
