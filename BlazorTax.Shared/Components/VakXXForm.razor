<EditForm Model="Data" class="vak4-form">

    <div class="vak2-title">Vak XX &ndash; BEZOLDIGINGEN VAN MEEWERKENDE ECHTGENOTEN</div>

    <div class="vak4-header-row"><div></div><div class="vak4-col-head">Belastingplichtige</div><div class="vak4-col-head">Partner</div></div>

    <div class="vak4-row">
        <div class="vak4-q-text">1. Toegekende bezoldigingen:</div>
        <div class="vak4-col-duo">
            <div class="vak4-input-cell"><span class="vak2-code">1450-00</span><InputNumber @bind-Value="Data.Code1450" class="vak4-amount" /></div>
            <div class="vak4-input-cell"><span class="vak2-code">2450-00</span><InputNumber @bind-Value="Data.Code2450" class="vak4-amount" /></div>
        </div>
    </div>

    <div class="vak4-row">
        <div class="vak4-q-text">2. Niet-ingehouden persoonlijke sociale bijdragen:</div>
        <div class="vak4-col-duo">
            <div class="vak4-input-cell"><span class="vak2-code">1451-00</span><InputNumber @bind-Value="Data.Code1451" class="vak4-amount" /></div>
            <div class="vak4-input-cell"><span class="vak2-code">2451-00</span><InputNumber @bind-Value="Data.Code2451" class="vak4-amount" /></div>
        </div>
    </div>

    <div class="vak4-row">
        <div class="vak4-q-text">3. Andere beroepskosten:</div>
        <div class="vak4-col-duo">
            <div class="vak4-input-cell"><span class="vak2-code">1452-00</span><InputNumber @bind-Value="Data.Code1452" class="vak4-amount" /></div>
            <div class="vak4-input-cell"><span class="vak2-code">2452-00</span><InputNumber @bind-Value="Data.Code2452" class="vak4-amount" /></div>
        </div>
    </div>

    <div class="vak4-row">
        <div class="vak4-q-text">4. Totaal bijberoep / student-zelfstandige:</div>
        <div class="vak4-col-duo">
            <div class="vak4-input-cell"><span class="vak2-code">1453-02</span><InputNumber @bind-Value="Data.Code1453" class="vak4-amount" /></div>
            <div class="vak4-input-cell"><span class="vak2-code">2453-69</span><InputNumber @bind-Value="Data.Code2453" class="vak4-amount" /></div>
        </div>
    </div>

    <!-- 5. Buitenlandse oorsprong -->
    <div class="vak2-section-header">Bezoldigingen van buitenlandse oorsprong</div>
    <div class="vak3-buitenland-section">
        @foreach (var rij in Data.BuitenlandseInkomsten)
        {
            <div class="vak3-buitenland-row">
                <div class="vak3-buitenland-cell"><label>Land:</label><InputText @bind-Value="rij.Land" class="vak3-text-input" /></div>
                <div class="vak3-buitenland-cell"><label>Code:</label><InputText @bind-Value="rij.Code" class="vak3-text-input vak3-code-input" /></div>
                <div class="vak3-buitenland-cell"><label>Bedrag:</label><InputNumber @bind-Value="rij.Bedrag" class="vak3-amount-input" /></div>
                <div class="vak3-buitenland-cell">
                    <label>Type:</label>
                    <InputSelect @bind-Value="rij.TypeVermindering" class="vak5-select">
                        <option value="">— kies —</option>
                        <option value="vrijstelling">Vrijstelling met progressievoorbehoud</option>
                        <option value="vermindering">Vermindering tot de helft</option>
                    </InputSelect>
                </div>
            </div>
        }
        <button type="button" class="vak3-add-btn" @onclick="() => Data.BuitenlandseInkomsten.Add(new())">+ rij</button>
    </div>

    <!-- 6. Datums -->
    <div class="vak4-header-row"><div></div><div class="vak4-col-head">Belastingplichtige</div><div class="vak4-col-head">Partner</div></div>

    <div class="vak4-row">
        <div class="vak4-q-text">Begindatum (dd/mm/jjjj):</div>
        <div class="vak4-col-duo">
            <div class="vak4-input-cell"><span class="vak2-code">1455-00</span><InputText @bind-Value="Data.Code1455" class="vak3-text-input" /></div>
            <div class="vak4-input-cell"><span class="vak2-code">2455-00</span><InputText @bind-Value="Data.Code2455" class="vak3-text-input" /></div>
        </div>
    </div>

    <div class="vak4-row">
        <div class="vak4-q-text">Einddatum (dd/mm/jjjj):</div>
        <div class="vak4-col-duo">
            <div class="vak4-input-cell"><span class="vak2-code">1456-00</span><InputText @bind-Value="Data.Code1456" class="vak3-text-input" /></div>
            <div class="vak4-input-cell"><span class="vak2-code">2456-00</span><InputText @bind-Value="Data.Code2456" class="vak3-text-input" /></div>
        </div>
    </div>

</EditForm>

@code {
    [Parameter] public VakXXData Data { get; set; } = new();
}
