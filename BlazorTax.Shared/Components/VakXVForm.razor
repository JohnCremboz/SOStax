            <div class="vak4-input-cell"><span class="vak2-code">1443-00</span><InputNumber @bind-Value="Data.Code1443" class="vak4-amount" /></div>
            <div class="vak4-input-cell"><span class="vak2-code">2443-00</span><InputNumber @bind-Value="Data.Code2443" class="vak4-amount" /></div>
        </div>
    </div>

    <div class="vak4-row">
        <div class="vak4-q-text">6. Kosten:</div>
        <div class="vak4-col-duo">
            <div class="vak4-input-cell"><span class="vak2-code">1198-00</span><InputNumber @bind-Value="Data.Code1198" class="vak4-amount" /></div>
            <div class="vak4-input-cell"><span class="vak2-code">2198-00</span><InputNumber @bind-Value="Data.Code2198" class="vak4-amount" /></div>
