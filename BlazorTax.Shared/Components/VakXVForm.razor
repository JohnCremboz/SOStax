            <div class="vak4-input-cell"><span class="vak2-code">2467-00</span><InputNumber @bind-Value="Data.Code2467" class="vak4-amount" /></div>
        </div>
    </div>

</EditForm>

@code {
    [Parameter] public VakXVData Data { get; set; } = new();
}
