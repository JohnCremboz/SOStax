<EditForm Model="Data" class="vak4-form">

    <div class="vak2-title">Vak XV &ndash; DIVERSE INKOMSTEN</div>

    <!-- ══ A. DIVERSE INKOMSTEN VAN ROERENDE AARD ══ -->
    <div class="vak2-section-header">A. DIVERSE INKOMSTEN VAN ROERENDE AARD</div>
    <div class="vak4-header-row"><div></div><div class="vak4-col-head">Belastingplichtige</div><div class="vak4-col-head">Partner</div></div>

    <div class="vak4-row">
        <div class="vak4-q-text">1. Niet-vrijgestelde inkomsten uit de verhuring, verpachting, gebruik en concessie van roerende goederen:</div>
        <div class="vak4-col-duo">
            <div class="vak4-input-cell"><span class="vak2-code">1440-00</span><InputNumber @bind-Value="Data.Code1440" class="vak4-amount" /></div>
            <div class="vak4-input-cell"><span class="vak2-code">2440-00</span><InputNumber @bind-Value="Data.Code2440" class="vak4-amount" /></div>
        </div>
    </div>

    <div class="vak4-row">
        <div class="vak4-q-text">2. Onderhoudsuitkeringen, lijfrenten en tijdelijke renten &ndash; belastbaar tegen 15%:</div>
        <div class="vak4-col-duo">
            <div class="vak4-input-cell"><span class="vak2-code">1179-00</span><InputNumber @bind-Value="Data.Code1179" class="vak4-amount" /></div>
            <div class="vak4-input-cell"><span class="vak2-code">2179-00</span><InputNumber @bind-Value="Data.Code2179" class="vak4-amount" /></div>
        </div>
