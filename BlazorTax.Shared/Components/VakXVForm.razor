            <div class="vak4-input-cell"><span class="vak2-code">1175-00</span><InputNumber @bind-Value="Data.Code1175" class="vak4-amount" /></div>
            <div class="vak4-input-cell"><span class="vak2-code">2175-00</span><InputNumber @bind-Value="Data.Code2175" class="vak4-amount" /></div>
