    <div class="vak4-row">
        <div class="vak4-q-text">11. Herziene aanschaffingswaarde:</div>
        <div class="vak4-col-duo">
            <div class="vak4-input-cell"><span class="vak2-code">1209-00</span><InputNumber @bind-Value="Data.Code1209" class="vak4-amount" /></div>
            <div class="vak4-input-cell"><span class="vak2-code">2209-00</span><InputNumber @bind-Value="Data.Code2209" class="vak4-amount" /></div>
        </div>
    </div>

    <div class="vak4-row">
        <div class="vak4-q-text">12. Meerwaarden op aandelen &ndash; afzonderlijk belastbaar tegen 33%:</div>
        <div class="vak4-col-duo">
            <div class="vak4-input-cell"><span class="vak2-code">1169-00</span><InputNumber @bind-Value="Data.Code1169" class="vak4-amount" /></div>
