        <div class="vak4-q-text">9. Meerwaarden op ongebouwde onroerende goederen &ndash; afzonderlijk belastbaar tegen 16,5%:</div>
        <div class="vak4-col-duo">
            <div class="vak4-input-cell"><span class="vak2-code">1177-00</span><InputNumber @bind-Value="Data.Code1177" class="vak4-amount" /></div>
            <div class="vak4-input-cell"><span class="vak2-code">2177-00</span><InputNumber @bind-Value="Data.Code2177" class="vak4-amount" /></div>
        </div>
    </div>

    <div class="vak4-row">
        <div class="vak4-q-text">10. Meerwaarden op gebouwde onroerende goederen &ndash; afzonderlijk belastbaar tegen 16,5%:</div>
        <div class="vak4-col-duo">
            <div class="vak4-input-cell"><span class="vak2-code">1178-00</span><InputNumber @bind-Value="Data.Code1178" class="vak4-amount" /></div>
