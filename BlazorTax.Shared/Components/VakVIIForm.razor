<EditForm Model="Data" class="vak4-form">

    <div class="vak2-title">Vak VII &ndash; INKOMSTEN VAN KAPITALEN EN ROERENDE GOEDEREN</div>

    <!-- ══ A. INKOMSTEN VAN KAPITALEN EN/OF CARRIED INTEREST ══ -->
    <div class="vak2-section-header">A. INKOMSTEN VAN KAPITALEN EN/OF CARRIED INTEREST VERKREGEN DOOR EEN CARRIED INTEREST BEGUNSTIGDE VÓÓR AFTREK VAN DE INNINGS- EN BEWARINGSKOSTEN:</div>
    <div class="vak4-header-row"><div></div><div class="vak4-col-head">Belastingplichtige</div><div class="vak4-col-head">Partner</div></div>

    <!-- 1. Niet verplicht -->
    <div class="vak4-group">
        <div class="vak4-q-label">1. Niet verplicht aan te geven inkomsten van kapitalen en/of van Carried interest en verrekenbare roerende voorheffing op vrijgestelde inkomsten</div>

        <div class="vak4-subrow"><div class="vak4-q-text vak4-indent">a) Niet verplicht aan te geven inkomsten van kapitalen (die niet van de personenbelasting zijn vrijgesteld):</div><div class="vak4-col-duo"></div></div>

        @foreach (var r in _rvRijen)
        {
            <div class="vak4-subrow">
                <div class="vak4-q-text vak4-indent2">@r.Label</div>
                <div class="vak4-col-duo">
                    <div class="vak4-input-cell"><span class="vak2-code">@r.Code1</span><InputNumber Value="@r.Get1(Data)" ValueChanged="@((decimal? v) => r.Set1(Data, v))" ValueExpression="@r.Expr1" class="vak4-amount" /></div>
                    <div class="vak4-input-cell"><span class="vak2-code">@r.Code2</span><InputNumber Value="@r.Get2(Data)" ValueChanged="@((decimal? v) => r.Set2(Data, v))" ValueExpression="@r.Expr2" class="vak4-amount" /></div>
                </div>
            </div>
        }

        <div class="vak4-subrow">
            <div class="vak4-q-text vak4-indent">b) Niet verplicht aan te geven inkomsten van Carried interest:</div>
            <div class="vak4-col-duo">
                <div class="vak4-input-cell"><span class="vak2-code">1167-94</span><InputNumber @bind-Value="Data.Code1167" class="vak4-amount" /></div>
                <div class="vak4-input-cell"><span class="vak2-code">2167-64</span><InputNumber @bind-Value="Data.Code2167" class="vak4-amount" /></div>
            </div>
        </div>
        <div class="vak4-subrow">
            <div class="vak4-q-text vak4-indent">c) Verrekenbare roerende voorheffing ingehouden op dividenden die voor maximaal 833 euro (1) van de personenbelasting zijn vrijgesteld:
                <div class="vak9-alert" style="margin-top:4px">
                    &#9432; Gewone dividenden zijn vrijgesteld tot <strong>&euro;&nbsp;833 per belastingplichtige</strong> (elk recht heeft op dit bedrag afzonderlijk). De vrijgestelde dividenden zelf mag u <em>niet</em> aangeven; alleen de erop ingehouden roerende voorheffing. Vrijstelling geldt niet voor dividenden van beleggingsfondsen of juridische constructies.
                </div>
            </div>
            <div class="vak4-col-duo">
                <div class="vak4-input-cell"><span class="vak2-code">1437-18</span><InputNumber @bind-Value="Data.Code1437" class="vak4-amount" /></div>
                <div class="vak4-input-cell"><span class="vak2-code">2437-85</span><InputNumber @bind-Value="Data.Code2437" class="vak4-amount" /></div>
            </div>
        </div>
    </div>

    <!-- 2. Verplicht aan te geven -->
    <div class="vak4-group">
        <div class="vak4-q-label">2. Verplicht aan te geven inkomsten</div>

        <div class="vak4-subrow">
            <div class="vak4-q-text vak4-indent">a) Inkomsten uit gereglementeerde spaardeposito's bij kredietinstellingen in de Europese Economische Ruimte, waarop geen roerende voorheffing is ingehouden (inkomen na aftrek van de per belastingplichtige vrijgestelde schijf van 1.020 euro (2)):
                <div class="vak9-alert" style="margin-top:4px">
                    &#9432; Elk belastingplichtige heeft recht op een vrijstelling van <strong>&euro;&nbsp;1.020</strong> op spaardeposito's. Alleen het <em>meerdere</em> boven &euro;&nbsp;1.020 vermelden hier. Belastbaar tegen 15&nbsp;%.
                </div>
            </div>
            <div class="vak4-col-duo">
                <div class="vak4-input-cell"><span class="vak2-code">1151-13</span><InputNumber @bind-Value="Data.Code1151" class="vak4-amount" /></div>
                <div class="vak4-input-cell"><span class="vak2-code">2151-80</span><InputNumber @bind-Value="Data.Code2151" class="vak4-amount" /></div>
            </div>
        </div>
        <div class="vak4-subrow">
            <div class="vak4-q-text vak4-indent">b) Inkomsten van Carried interest zonder roerende voorheffing:</div>
            <div class="vak4-col-duo">
                <div class="vak4-input-cell"><span class="vak2-code">1442-13</span><InputNumber @bind-Value="Data.Code1442" class="vak4-amount" /></div>
                <div class="vak4-input-cell"><span class="vak2-code">2442-80</span><InputNumber @bind-Value="Data.Code2442" class="vak4-amount" /></div>
            </div>
        </div>

        <div class="vak4-subrow"><div class="vak4-q-text vak4-indent">c) Andere inkomsten zonder roerende voorheffing:</div><div class="vak4-col-duo"></div></div>
        <div class="vak4-subrow">
            <div class="vak4-q-text vak4-indent2">1) die belastbaar zijn tegen 30%:</div>
            <div class="vak4-col-duo">
                <div class="vak4-input-cell"><span class="vak2-code">1444-11</span><InputNumber @bind-Value="Data.Code1444" class="vak4-amount" /></div>
                <div class="vak4-input-cell"><span class="vak2-code">2444-78</span><InputNumber @bind-Value="Data.Code2444" class="vak4-amount" /></div>
            </div>
        </div>
        <div class="vak4-subrow">
            <div class="vak4-q-text vak4-indent2">2) die belastbaar zijn tegen 20%:</div>
            <div class="vak4-col-duo">
                <div class="vak4-input-cell"><span class="vak2-code">1159-05</span><InputNumber @bind-Value="Data.Code1159" class="vak4-amount" /></div>
                <div class="vak4-input-cell"><span class="vak2-code">2159-72</span><InputNumber @bind-Value="Data.Code2159" class="vak4-amount" /></div>
            </div>
        </div>
        <div class="vak4-subrow">
            <div class="vak4-q-text vak4-indent2">3) die belastbaar zijn tegen 15%:</div>
            <div class="vak4-col-duo">
                <div class="vak4-input-cell"><span class="vak2-code">1445-10</span><InputNumber @bind-Value="Data.Code1445" class="vak4-amount" /></div>
                <div class="vak4-input-cell"><span class="vak2-code">2445-77</span><InputNumber @bind-Value="Data.Code2445" class="vak4-amount" /></div>
            </div>
        </div>
        <div class="vak4-subrow">
            <div class="vak4-q-text vak4-indent2">4) die belastbaar zijn tegen 6,5%:</div>
            <div class="vak4-col-duo">
                <div class="vak4-input-cell"><span class="vak2-code">1446-09</span><InputNumber @bind-Value="Data.Code1446" class="vak4-amount" /></div>
                <div class="vak4-input-cell"><span class="vak2-code">2446-76</span><InputNumber @bind-Value="Data.Code2446" class="vak4-amount" /></div>
            </div>
        </div>
        <div class="vak4-subrow">
            <div class="vak4-q-text vak4-indent2">5) die belastbaar zijn tegen 5%:</div>
            <div class="vak4-col-duo">
                <div class="vak4-input-cell"><span class="vak2-code">1448-07</span><InputNumber @bind-Value="Data.Code1448" class="vak4-amount" /></div>
                <div class="vak4-input-cell"><span class="vak2-code">2448-74</span><InputNumber @bind-Value="Data.Code2448" class="vak4-amount" /></div>
            </div>
        </div>
    </div>

    <!-- ══ B. NETTO-INKOMEN VERHUUR/VERPACHTING ══ -->
    <div class="vak2-section-header">B. NETTO-INKOMEN UIT VERHURING, VERPACHTING, GEBRUIK OF CONCESSIE VAN ROERENDE GOEDEREN:</div>
    <div class="vak4-header-row"><div></div><div class="vak4-col-head">Belastingplichtige</div><div class="vak4-col-head">Partner</div></div>
    <div class="vak4-row">
        <div class="vak4-q-text"></div>
        <div class="vak4-col-duo">
            <div class="vak4-input-cell"><span class="vak2-code">1156-08</span><InputNumber @bind-Value="Data.Code1156" class="vak4-amount" /></div>
            <div class="vak4-input-cell"><span class="vak2-code">2156-75</span><InputNumber @bind-Value="Data.Code2156" class="vak4-amount" /></div>
        </div>
    </div>

    <!-- ══ C. LIJFRENTEN / TIJDELIJKE RENTEN ══ -->
    <div class="vak2-section-header">C. INKOMSTEN BEGREPEN IN LIJFRENTEN OF TIJDELIJKE RENTEN:</div>
    <div class="vak4-header-row"><div></div><div class="vak4-col-head">Belastingplichtige</div><div class="vak4-col-head">Partner</div></div>
    <div class="vak4-row">
        <div class="vak4-q-text"></div>
        <div class="vak4-col-duo">
            <div class="vak4-input-cell"><span class="vak2-code">1158-06</span><InputNumber @bind-Value="Data.Code1158" class="vak4-amount" /></div>
            <div class="vak4-input-cell"><span class="vak2-code">2158-73</span><InputNumber @bind-Value="Data.Code2158" class="vak4-amount" /></div>
        </div>
    </div>

    <!-- ══ D. AUTEURSRECHTEN ══ -->
    <div class="vak2-section-header">D. INKOMSTEN UIT AUTEURSRECHTEN, NABURIGE RECHTEN EN WETTELIJKE EN VERPLICHTE LICENTIES:</div>
    <div class="vak4-header-row"><div></div><div class="vak4-col-head">Belastingplichtige</div><div class="vak4-col-head">Partner</div></div>
    <div class="vak4-row">
        <div class="vak4-q-text">1. Inkomsten (bruto):</div>
        <div class="vak4-col-duo">
            <div class="vak4-input-cell"><span class="vak2-code">1123-41</span><InputNumber @bind-Value="Data.Code1123" class="vak4-amount" /></div>
            <div class="vak4-input-cell"><span class="vak2-code">2123-11</span><InputNumber @bind-Value="Data.Code2123" class="vak4-amount" /></div>
        </div>
    </div>
    <div class="vak4-row">
        <div class="vak4-q-text">2. Kosten (werkelijke of forfaitaire):</div>
        <div class="vak4-col-duo">
            <div class="vak4-input-cell"><span class="vak2-code">1124-40</span><InputNumber @bind-Value="Data.Code1124" class="vak4-amount" /></div>
            <div class="vak4-input-cell"><span class="vak2-code">2124-10</span><InputNumber @bind-Value="Data.Code2124" class="vak4-amount" /></div>
        </div>
    </div>
    <div class="vak4-row">
        <div class="vak4-q-text">3. Roerende voorheffing:</div>
        <div class="vak4-col-duo">
            <div class="vak4-input-cell"><span class="vak2-code">1119-45</span><InputNumber @bind-Value="Data.Code1119" class="vak4-amount" /></div>
            <div class="vak4-input-cell"><span class="vak2-code">2119-15</span><InputNumber @bind-Value="Data.Code2119" class="vak4-amount" /></div>
        </div>
    </div>

    <!-- ══ E. INNINGS- EN BEWARINGSKOSTEN ══ -->
    <div class="vak2-section-header">E. INNINGS- EN BEWARINGSKOSTEN BETREFFENDE AANGEGEVEN INKOMSTEN:</div>
    <div class="vak4-header-row"><div></div><div class="vak4-col-head">Belastingplichtige</div><div class="vak4-col-head">Partner</div></div>
    <div class="vak4-row">
        <div class="vak4-q-text"></div>
        <div class="vak4-col-duo">
            <div class="vak4-input-cell"><span class="vak2-code">1170-91</span><InputNumber @bind-Value="Data.Code1170" class="vak4-amount" /></div>
            <div class="vak4-input-cell"><span class="vak2-code">2170-61</span><InputNumber @bind-Value="Data.Code2170" class="vak4-amount" /></div>
        </div>
    </div>

    <!-- ══ F. BIJZONDER AANSLAGSTELSEL ══ -->
    <div class="vak2-section-header">F. INKOMSTEN WAAROP EEN BIJZONDER AANSLAGSTELSEL VAN TOEPASSING IS</div>
    <div class="vak3-buitenland-hint">
        Als u hiervoor inkomsten hebt vermeld waarop een bijzonder aanslagstelsel van toepassing is, vermeld het land, de code waarnaast ze zijn vermeld, het bedrag en de aard van de inkomsten:
    </div>
    <div class="vak3-buitenland-section">
        @foreach (var rij in Data.BijzonderAanslag)
        {
            <div class="vak3-buitenland-row">
                <div class="vak3-buitenland-cell"><label>Land:</label><InputText @bind-Value="rij.Land" class="vak3-text-input" /></div>
                <div class="vak3-buitenland-cell"><label>Code:</label><InputText @bind-Value="rij.Code" class="vak3-text-input vak3-code-input" /></div>
                <div class="vak3-buitenland-cell"><label>Bedrag:</label><InputNumber @bind-Value="rij.Bedrag" class="vak3-amount-input" /></div>
                <div class="vak3-buitenland-cell"><label>Aard:</label><InputText @bind-Value="rij.Aard" class="vak3-text-input" /></div>
            </div>
        }
        <button type="button" class="vak3-add-btn" @onclick="() => Data.BijzonderAanslag.Add(new())">+ rij</button>
    </div>

</EditForm>

@code {
    [Parameter] public VakVIIData Data { get; set; } = new();

    private record RvRij(
        string Label, string Code1, string Code2,
        Func<VakVIIData, decimal?> Get1, Action<VakVIIData, decimal?> Set1,
        Func<VakVIIData, decimal?> Get2, Action<VakVIIData, decimal?> Set2,
        System.Linq.Expressions.Expression<Func<decimal?>> Expr1,
        System.Linq.Expressions.Expression<Func<decimal?>> Expr2);

    private RvRij[] _rvRijen => [
        new("1) met roerende voorheffing van 30%:", "1160-04", "2160-71", d => d.Code1160, (d,v) => d.Code1160=v, d => d.Code2160, (d,v) => d.Code2160=v, () => Data.Code1160, () => Data.Code2160),
        new("2) met roerende voorheffing van 20%:", "1161-03", "2161-70", d => d.Code1161, (d,v) => d.Code1161=v, d => d.Code2161, (d,v) => d.Code2161=v, () => Data.Code1161, () => Data.Code2161),
        new("3) met roerende voorheffing van 15%:", "1162-02", "2162-69", d => d.Code1162, (d,v) => d.Code1162=v, d => d.Code2162, (d,v) => d.Code2162=v, () => Data.Code1162, () => Data.Code2162),
        new("4) met roerende voorheffing van 6,5%:", "1163-01", "2163-68", d => d.Code1163, (d,v) => d.Code1163=v, d => d.Code2163, (d,v) => d.Code2163=v, () => Data.Code1163, () => Data.Code2163),
        new("5) met roerende voorheffing van 5%:",  "1436-19", "2436-86", d => d.Code1436, (d,v) => d.Code1436=v, d => d.Code2436, (d,v) => d.Code2436=v, () => Data.Code1436, () => Data.Code2436),
    ];
}

