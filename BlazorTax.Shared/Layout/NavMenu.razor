@inject AangifteStateService StateService
@inject NavigationManager Nav

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">
            <img class="brand-logo me-2" src="_content/BlazorTax.Shared/images/lifebuoy-logo.svg" alt="SOStax logo" />
            <strong>SOS</strong>tax
        </a>
        <button title="Navigation menu" class="navbar-toggler" @onclick="ToggleNavMenu">
            <span class="navbar-toggler-icon"></span>
        </button>
    </div>
</div>

<div class="@NavMenuCssClass nav-scrollable" @onclick="ToggleNavMenu">
    <nav class="nav flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="material-icons nav-icon">home</span> Home
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="belastingen">
                <span class="material-icons nav-icon">calculate</span> Belastingen
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="snelle-invoer">
                <span class="material-icons nav-icon">flash_on</span> Snelle Invoer
            </NavLink>
        </div>

        <hr class="nav-divider" />

        <div class="nav-item px-3">
            <button class="nav-link btn btn-link w-100 text-start" @onclick="OpslaanAsync" disabled="@_bezig">
                <span class="material-icons nav-icon">save</span> Opslaan
            </button>
        </div>
        <div class="nav-item px-3">
            <button class="nav-link btn btn-link w-100 text-start" @onclick="OpenAsync" disabled="@_bezig">
                <span class="material-icons nav-icon">folder_open</span> Openen
            </button>
        </div>
        <div class="nav-item px-3">
            <button class="nav-link btn btn-link w-100 text-start" @onclick="NieuweAangifteAsync" disabled="@_bezig">
                <span class="material-icons nav-icon">add</span> Nieuwe aangifte
            </button>
        </div>

        @if (!string.IsNullOrEmpty(_melding))
        {
            <div class="nav-melding px-3 mt-1">@_melding</div>
        }
    </nav>
</div>

@code {
    private bool collapseNavMenu = true;
    private bool _bezig;
    private string _melding = string.Empty;

    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }

    private async Task OpslaanAsync()
    {
        _bezig = true;
        _melding = string.Empty;
        try
        {
            await StateService.OpslaanAsync();
            _melding = "Opgeslagen.";
        }
        catch (Exception ex)
        {
            _melding = $"Fout: {ex.Message}";
        }
        finally
        {
            _bezig = false;
            StateHasChanged();
        }
    }

    private async Task OpenAsync()
    {
        _bezig = true;
        _melding = string.Empty;
        try
        {
            bool geladen = await StateService.OpenAsync();
            _melding = geladen ? "Aangifte geladen." : string.Empty;
            if (geladen)
                Nav.NavigateTo("belastingen");
        }
        catch (Exception ex)
        {
            _melding = $"Fout: {ex.Message}";
        }
        finally
        {
            _bezig = false;
            StateHasChanged();
        }
    }

    private Task NieuweAangifteAsync()
    {
        StateService.NieuweAangifte();
        Nav.NavigateTo("belastingen");
        return Task.CompletedTask;
    }
}
