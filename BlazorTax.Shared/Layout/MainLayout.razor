@inherits LayoutComponentBase
@inject AangifteStateService StateService

<div class="page">
    <div class="sidebar">
        <NavMenu/>
    </div>

    <main>
        <div class="top-row px-4">
            <span class="sostax-topbar-title">SOStax – Personenbelasting AJ 2026</span>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

@code {
    protected override async Task OnInitializedAsync()
    {
        await StateService.AutoOpenAsync();
    }
}